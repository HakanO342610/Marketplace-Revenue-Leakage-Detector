# =====================================================================
# MRLD — Production env template (IP-only deployment, no domain yet)
#
# Copy on Hetzner server:
#   cp .env.prod.example .env
# Then run:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d --build
# =====================================================================

# Postgres in-Docker password (uppercase, mixed, 24+ chars)
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_OPENSSL_RAND_BASE64_32

# JWT secret (64-char hex)
# Generate: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_64

# JWT expiry (7d default — login session length)
JWT_EXPIRES_IN=7d

# Telegram alerts — shared xpensio_alerts channel
# (Xpensio'da kullanılan aynı bot ve chat ID'sini gir)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
