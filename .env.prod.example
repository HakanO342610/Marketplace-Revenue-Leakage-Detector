# =====================================================================
# MRLD — Production Environment Template
# Copy to .env on the prod server: cp .env.prod.example .env
# Then docker compose -f docker-compose.prod.yml --env-file .env up -d
# =====================================================================

# --- Domain (Caddy auto-SSL) ---
# Must point to this server (A record, optionally AAAA).
# Without DNS pointing here, Let's Encrypt cert issuance will fail.
DOMAIN=mrld.example.com

# --- Hetzner Postgres ---
# CX23 server — IP 89.167.115.209 — replace USER/PASSWORD/DBNAME
# sslmode=require unless you've explicitly disabled SSL on the host.
DATABASE_URL=postgresql://USER:PASSWORD@89.167.115.209:5432/DBNAME?schema=public&sslmode=require

# --- JWT ---
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_HEX_64
JWT_EXPIRES_IN=7d
