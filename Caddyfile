# Caddy auto-issues a Let's Encrypt cert for ${DOMAIN} on first request.
# Make sure DNS A/AAAA record points to the server's public IP before
# starting compose, otherwise the ACME challenge will fail.

{$DOMAIN} {
    encode gzip zstd

    # Backend API
    handle_path /api/* {
        reverse_proxy backend:3101 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
        # Re-prepend /api so NestJS global prefix matches
        rewrite * /api{uri}
    }

    # Everything else -> Next.js
    handle {
        reverse_proxy frontend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Standard hardening headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }

    log {
        output stdout
        format console
    }
}
